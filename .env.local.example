# =============================================================
# SUPABASE
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service Role key — NUNCA expongas esto en el cliente
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================
# CRON (proteger endpoints /api/cron/*)
# Generar con: openssl rand -hex 32
# =============================================================
CRON_SECRET=your-cron-secret

# =============================================================
# EMISOR (datos que aparecen en los PDFs generados)
# Fallback si no están configurados en la tabla company_settings de Supabase
# =============================================================
EMISOR_NAME=Nombre de la empresa
EMISOR_ADDRESS=Dirección completa
EMISOR_CITY=Ciudad
EMISOR_CIF=B00000000

# =============================================================
# WEBHOOKS n8n
# Los eventos de Supabase (INSERT/UPDATE) disparan primero a /api/webhooks/*
# que enriquecen el payload con joins antes de llamar a n8n
# =============================================================

# Nuevo ticket creado
NEW_TICKET_WEBHOOK=https://your-n8n-instance.com/webhook/new-ticket

# Nueva deuda creada
NEW_DEBT_WEBHOOK=https://your-n8n-instance.com/webhook/new-debt

# Ticket resuelto
RESOLVED_TICKET_WEBHOOK=https://your-n8n-instance.com/webhook/resolved-ticket

# Deuda resuelta
RESOLVED_DEBT_WEBHOOK=https://your-n8n-instance.com/webhook/resolved-debt

# Envío de documentos por email (certificados, suplidos, varios, fichaje)
EMAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/send-email

# Importación de tickets desde PDF
IMPORT_TICKETS_PDF_WEBHOOK=https://your-n8n-instance.com/webhook/import-tickets-pdf

# Informe de comunidad por email
COMMUNITY_REPORT_EMAIL_WEBHOOK=https://your-n8n-instance.com/webhook/community-report

# Listado de carpetas OneDrive (facturas comunidades)
ONEDRIVE_FOLDERS_WEBHOOK=https://your-n8n-instance.com/webhook/onedrive-folders
