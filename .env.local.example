# =============================================================================
# SUPABASE
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose in client code

# =============================================================================
# RESEND (email transaccional)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tudominio.com

# =============================================================================
# CRON (proteger endpoint /api/cron/*)
# Generar con: openssl rand -hex 32
# =============================================================================
CRON_SECRET=your-cron-secret

# =============================================================================
# WEBHOOKS n8n
# =============================================================================
RESOLVED_DEBT_WEBHOOK=https://your-n8n.com/webhook/resolved-debt
RESOLVED_TICKET_WEBHOOK=https://your-n8n.com/webhook/resolved-ticket
DEBT_WEBHOOK_URL=https://your-n8n.com/webhook/debt
EMAIL_WEBHOOK_URL=https://your-n8n.com/webhook/email
IMPORT_TICKETS_PDF_WEBHOOK=https://your-n8n.com/webhook/import-tickets-pdf
NEXT_PUBLIC_IMPORT_TICKETS_PDF_WEBHOOK=https://your-n8n.com/webhook/import-tickets-pdf
NEXT_PUBLIC_INCIDENT_WEBHOOK=https://your-n8n.com/webhook/incident

# =============================================================================
# DATOS DEL EMISOR (aparecen en PDFs y footer)
# Se pueden gestionar también desde la tabla company_settings en Supabase
# =============================================================================
EMISOR_NAME=Nombre de tu comunidad o gestoría
EMISOR_CIF=B00000000
EMISOR_ADDRESS=Calle Ejemplo, 1
EMISOR_CITY=Madrid
